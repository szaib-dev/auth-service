{
  "name": "codersgyan",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=dev nodemon -L --exec tsx src/server.ts",
    "prod": "cross-env NODE_ENV=prod tsx src/server.ts",
    "prepare": "husky",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "pr:fix": "prettier . --write",
    "pr:check": "prettier . --check",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules NODE_ENV=dev jest",
    "test-w": "cross-env NODE_OPTIONS=--experimental-vm-modules  NODE_ENV=dev   jest --watch",
    "docker:dev": "docker run --rm -it -v \"%cd%:/usr/src/app\" -v auth-service_nodemodules:/usr/src/app/node_modules --env-file \"%cd%/.env.docker\" --network coder-gyan-network -p 5500:5501 -e NODE_ENV=dev auth-service:latest",
    "docker:db": "docker run --rm --name mernpg-container -e POSTGRES_USER=root -e POSTGRES_PASSWORD=root -v pgmern:/var/lib/postgresql/data --network coder-gyan-network -p 5000:5432 -d postgres:17"
  },
  "keywords": [],
  "author": "",
  "type": "module",
  "license": "ISC",
  "packageManager": "pnpm@10.28.1",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/http-errors": "^2.0.5",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.0.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "prettier": "3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "dependencies": {
    "@middy/http-error-handler": "^7.1.7",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "http-errors": "^2.0.1",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "winston": "^3.19.0"
  }
}
